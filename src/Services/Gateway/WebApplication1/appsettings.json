{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "catalog-route": {
        "ClusterId": "ticket-cluster",
        "Match": {
          "Path": "/tickets/{**catch-all}"
        }
      },
      "basket-route": {
        "ClusterId": "basket-cluster",
        "Match": {
          "Path": "/baskets/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "ticket-cluster": {
        "Destinations": {
          "httpCatalog": {
            "Address": "http://localhost:5000/"
          },
          "httpsCatalog": {
            "Address": "https://localhost:5050"
          }
        }
      },
    "basket-cluster": {
        "Destinations": {
            "httpBasket": {
              "Address": "http://localhost:5001"
            },
            "httpsBasket": {
              "Address": "https://localhost:5051"
            }
          }
      },
      "auth-cluster": {
        "Destinations": {
          "http-auth-address": {
            "Address": "http://localhost:5279"
          },
          "https-auth-address": {
            "Address": "https://localhost:7067"
          }
        }
      }
    }
  }
}
