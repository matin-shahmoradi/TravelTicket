{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "Properties": {
      "Application": "TravelTicket-microservice",
      "Environmet": "Delevopment"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgresDefaultConnection": ""
  },
  "MessageBroker": {
    "Host": "amqp://localhost:5672",
    "UserName": "",
    "Password": ""
  }
}
